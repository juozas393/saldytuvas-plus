  }
}

' 3) DOMAIN MODEL (bendras abiems posistemėms)
package "DomainModel" {
  
  package "Entities" {
    ' Visos 19 Entities iš jūsų modelio
    [Administrator <<entity>>]
    [Budget <<entity>>]
    [Category <<entity>>]
    [Deal <<entity>>]
    [Dish <<entity>>]
    [Environment <<entity>>]
    [FoodRule <<entity>>]
    [Inventory <<entity>>]
    [Member <<entity>>]
    [Notification <<entity>>]
    [NutritionPlan <<entity>>]
    [Product <<entity>>]
    [PromoFlyer <<entity>>]
    [Receipt <<entity>>]
    [ReceiptLine <<entity>>]
    [Recipe <<entity>>]
    [ShoppingList <<entity>>]
    [Store <<entity>>]
    [User <<entity>>]
  }
  
  package "Enumerations" {
    ' Visi 7 Enumerations iš jūsų modelio
    [DishType <<enumeration>>]
    [FoodRuleStatus <<enumeration>>]
    [Gender <<enumeration>>]
    [MealPlanStatus <<enumeration>>]
    [NotificationLevel <<enumeration>>]
    [StorePriority <<enumeration>>]
    [UserRole <<enumeration>>]
  }
}

' 4) DATA ACCESS LAYER (bendras)
package "DataAccess" {
  
  package "Repositories" {
    [IInventoryRepository]
    [IReceiptRepository]
    [IBudgetRepository]
    [IMealPlanRepository]
    [IShoppingListRepository]
    [IRecipeRepository]
    [IUserRepository]
    [IDealsRepository]
    [ICategoryRepository]
    [INotificationRepository]
  }
  
  package "SupabaseGateway" {
    [SupabaseGateway <<boundary>>]
  }
}

' 5) EXTERNAL SERVICES / DEVICE ADAPTERS (bendras)
package "ExternalServices" {
  [CameraGalleryBoundary <<boundary>>]
  [GeminiServiceBoundary <<boundary>>]
  [OCRServiceBoundary <<boundary>>]
  [OpenFoodFactsServiceBoundary <<boundary>>]
  [SpoonacularServiceBoundary <<boundary>>]
  [MobileScannerBoundary <<boundary>>]
}

' 6) CORE (cross-cutting, bendras)
package "Core" {
